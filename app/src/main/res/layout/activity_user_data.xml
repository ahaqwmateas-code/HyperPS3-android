<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="fill_parent"
	android:layout_height="fill_parent"
	android:orientation="vertical">

	<androidx.appcompat.widget.Toolbar
		android:id="@+id/toolbar"
		android:layout_width="match_parent"
		android:layout_height="?attr/actionBarSize"
		android:background="?attr/colorPrimary"
		android:elevation="4dp"
		android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
		app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

	<FrameLayout
		android:id="@+id/content_frame"
		android:layout_width="match_parent"
		android:layout_height="match_parent">

		<!-- 主菜单 -->
		<ListView
			android:id="@+id/list_main"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:scrollbars="vertical" />
		
		<!-- PPU缓存管理 -->
		<LinearLayout
			android:id="@+id/ppu_cache_view"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:visibility="gone">
			
			<Button
				android:id="@+id/btn_ppu_import"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/import_ppu_cache"
				android:layout_margin="8dp" />
			
			<ListView
				android:id="@+id/list_ppu_cache"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:scrollbars="vertical" />
		</LinearLayout>
		
		<!-- ISO 目录管理 -->
		<LinearLayout
			android:id="@+id/iso_dir_view"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:visibility="gone">
			
			<Button
				android:id="@+id/btn_iso_dir_add"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/add_a_iso_dir"
				android:layout_margin="8dp" />
			
			<ListView
				android:id="@+id/list_iso_dir"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:scrollbars="vertical" />
		</LinearLayout>
		
		<!-- 兼容性表 -->
		<LinearLayout
			android:id="@+id/compatibility_table_view"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:visibility="gone">
			
			<Button
				android:id="@+id/btn_compat_download"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/download_compatibility_data_sheet"
				android:layout_margin="8dp" />
			<ScrollView
				android:layout_width="match_parent"
				android:layout_height="match_parent">

				<TextView
					android:id="@+id/text_compat_content"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:scrollbars="vertical" />

			</ScrollView>

		</LinearLayout>
		
		<!-- 驱动管理 -->
		<ListView
			android:id="@+id/list_driver"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:scrollbars="vertical"
			android:visibility="gone" />

		<!-- 游戏数据管理 -->
		<LinearLayout
			android:id="@+id/game_data_view"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:visibility="gone"
			android:gravity="top|center_horizontal"
			android:padding="16dp">
			
			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/game_data_manager_desc"
				android:textSize="14sp"
				android:textColor="?android:attr/textColorSecondary"
				android:layout_marginBottom="24dp"
				android:gravity="center" />
			
			<Button
				android:id="@+id/btn_game_data_import"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/import_game_data"
				android:layout_marginBottom="12dp" />
			
			<Button
				android:id="@+id/btn_game_data_export"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/export_game_data" />
		</LinearLayout>

		
	</FrameLayout>
</LinearLayout>
